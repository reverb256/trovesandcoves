# Environment Configuration Template
# Troves & Coves - Crystal Jewelry Showcase Site

# ============================================================================
# CURRENTLY USED
# ============================================================================

# Deployment URLs
VITE_API_URL=http://localhost:5000
VITE_CLOUDFLARE_API=https://api.trovesandcoves.ca
VITE_GITHUB_PAGES_URL=https://trovesandcoves.ca

# Base path for GitHub Pages (no longer needed with custom domain)
VITE_BASE_PATH=/

# ============================================================================
# OPTIONAL - For Future Development
# ============================================================================

# Session secret for cart management
SESSION_SECRET=change-this-to-a-random-string-in-production

# Database - Would enable PostgreSQL storage (Phase 1, Roadmap)
# DATABASE_URL=postgresql://user:password@localhost:5432/trovesandcoves

# Cloudflare Workers - For serverless deployment (optional)
# CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
# CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# Analytics (optional)
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
